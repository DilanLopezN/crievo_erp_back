generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["core", "rh", "financeiro"]
}

// ============================================================
// CORE SCHEMA: Multi-Tenant & Authentication
// Modelos fundamentais do sistema multi-tenant
// ============================================================

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  domain    String?  @unique
  logo      String?
  isActive  Boolean  @default(true) @map("is_active")
  plan      Plan     @default(FREE)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relações Core
  users       User[]
  invitations Invitation[]

  // Relações RH
  departments   Department[]
  positions     Position[]
  workSchedules WorkSchedule[]
  employees     Employee[]
  timeRecords   TimeRecord[]
  leaves        Leave[]

  // Relações Financeiro
  financialCategories   FinancialCategory[]
  costCenters           CostCenter[]
  bankAccounts          BankAccount[]
  accountsPayable       AccountPayable[]
  accountsReceivable    AccountReceivable[]
  financialTransactions FinancialTransaction[]
  bankStatements        BankStatement[]

  @@map("tenants")
  @@schema("core")
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  email        String
  passwordHash String    @map("password_hash")
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  role         Role      @default(MEMBER)
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
  @@schema("core")
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
  @@schema("core")
}

model Invitation {
  id        String           @id @default(uuid()) @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  email     String
  role      Role             @default(MEMBER)
  status    InvitationStatus @default(PENDING)
  token     String           @unique
  expiresAt DateTime         @map("expires_at")
  createdAt DateTime         @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("invitations")
  @@schema("core")
}

// ============================================================
// CORE SCHEMA: Enums
// ============================================================

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE

  @@schema("core")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER

  @@schema("core")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELLED

  @@schema("core")
}

// ============================================================
// RH SCHEMA: Recursos Humanos
// Gestão de departamentos, cargos, funcionários,
// escalas de trabalho, ponto eletrônico e licenças
// ============================================================

model Department {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String?
  parentId    String?  @map("parent_id") @db.Uuid
  managerId   String?  @map("manager_id") @db.Uuid
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id])
  children  Department[] @relation("DepartmentHierarchy")
  positions Position[]
  employees Employee[]

  @@index([tenantId])
  @@map("departments")
  @@schema("rh")
}

model Position {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @map("tenant_id") @db.Uuid
  departmentId  String?       @map("department_id") @db.Uuid
  name          String
  description   String?
  level         PositionLevel @default(JUNIOR)
  baseSalaryMin Decimal?      @map("base_salary_min") @db.Decimal(12, 2)
  baseSalaryMax Decimal?      @map("base_salary_max") @db.Decimal(12, 2)
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  department Department? @relation(fields: [departmentId], references: [id])
  employees  Employee[]

  @@index([tenantId])
  @@map("positions")
  @@schema("rh")
}

model WorkSchedule {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  workDays      Json     @map("work_days")
  entryTime     String   @map("entry_time")
  exitTime      String   @map("exit_time")
  lunchDuration Int      @default(60) @map("lunch_duration")
  weeklyHours   Decimal  @default(44) @map("weekly_hours") @db.Decimal(5, 2)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employees Employee[]

  @@index([tenantId])
  @@map("work_schedules")
  @@schema("rh")
}

model Employee {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  userId          String?        @map("user_id") @db.Uuid
  positionId      String?        @map("position_id") @db.Uuid
  departmentId    String?        @map("department_id") @db.Uuid
  workScheduleId  String?        @map("work_schedule_id") @db.Uuid
  employeeCode    String         @map("employee_code")
  firstName       String         @map("first_name")
  lastName        String         @map("last_name")
  email           String
  phone           String?
  cpf             String?
  rg              String?
  birthDate       DateTime?      @map("birth_date") @db.Date
  hireDate        DateTime       @map("hire_date") @db.Date
  terminationDate DateTime?      @map("termination_date") @db.Date
  contractType    ContractType   @default(CLT) @map("contract_type")
  salary          Decimal?       @db.Decimal(12, 2)
  status          EmployeeStatus @default(ACTIVE)
  photo           String?
  address         Json?
  emergencyContact Json?         @map("emergency_contact")
  bankInfo        Json?          @map("bank_info")
  notes           String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  position     Position?     @relation(fields: [positionId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])
  workSchedule WorkSchedule? @relation(fields: [workScheduleId], references: [id])
  timeRecords  TimeRecord[]
  leaves       Leave[]

  @@unique([tenantId, employeeCode])
  @@unique([tenantId, cpf])
  @@index([tenantId])
  @@map("employees")
  @@schema("rh")
}

model TimeRecord {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @map("tenant_id") @db.Uuid
  employeeId     String           @map("employee_id") @db.Uuid
  date           DateTime         @db.Date
  entryTime      DateTime?        @map("entry_time")
  lunchStartTime DateTime?        @map("lunch_start_time")
  lunchEndTime   DateTime?        @map("lunch_end_time")
  exitTime       DateTime?        @map("exit_time")
  workedMinutes  Int?             @map("worked_minutes")
  extraMinutes   Int?             @map("extra_minutes")
  missingMinutes Int?             @map("missing_minutes")
  type           TimeRecordType   @default(NORMAL)
  status         TimeRecordStatus @default(PENDING)
  location       Json?
  notes          String?
  adjustedById   String?          @map("adjusted_by_id") @db.Uuid
  adjustedAt     DateTime?        @map("adjusted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([tenantId, employeeId, date])
  @@index([tenantId])
  @@index([employeeId])
  @@map("time_records")
  @@schema("rh")
}

model Leave {
  id           String      @id @default(uuid()) @db.Uuid
  tenantId     String      @map("tenant_id") @db.Uuid
  employeeId   String      @map("employee_id") @db.Uuid
  type         LeaveType
  startDate    DateTime    @map("start_date") @db.Date
  endDate      DateTime    @map("end_date") @db.Date
  days         Int
  status       LeaveStatus @default(PENDING)
  reason       String?
  approvedById String?     @map("approved_by_id") @db.Uuid
  approvedAt   DateTime?   @map("approved_at")
  rejectedNote String?     @map("rejected_note")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([employeeId])
  @@map("leaves")
  @@schema("rh")
}

// ============================================================
// RH SCHEMA: Enums
// ============================================================

enum PositionLevel {
  INTERN
  JUNIOR
  PLENO
  SENIOR
  SPECIALIST
  COORDINATOR
  MANAGER
  DIRECTOR
  C_LEVEL

  @@schema("rh")
}

enum ContractType {
  CLT
  PJ
  INTERN
  TEMPORARY
  FREELANCER

  @@schema("rh")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED

  @@schema("rh")
}

enum TimeRecordType {
  NORMAL
  OVERTIME
  REMOTE
  HOLIDAY
  COMPENSATORY

  @@schema("rh")
}

enum TimeRecordStatus {
  PENDING
  APPROVED
  REJECTED
  ADJUSTED

  @@schema("rh")
}

enum LeaveType {
  VACATION
  SICK
  MATERNITY
  PATERNITY
  PERSONAL
  BEREAVEMENT
  OTHER

  @@schema("rh")
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED

  @@schema("rh")
}

// ============================================================
// FINANCEIRO SCHEMA: Gestão Financeira
// Categorias, centros de custo, contas bancárias,
// contas a pagar/receber, transações e conciliação
// ============================================================

model FinancialCategory {
  id          String                @id @default(uuid()) @db.Uuid
  tenantId    String                @map("tenant_id") @db.Uuid
  name        String
  code        String?
  type        FinancialCategoryType
  dreGroup    DreGroup?             @map("dre_group")
  parentId    String?               @map("parent_id") @db.Uuid
  description String?
  isActive    Boolean               @default(true) @map("is_active")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")

  tenant   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   FinancialCategory?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children FinancialCategory[] @relation("CategoryHierarchy")

  accountsPayable    AccountPayable[]
  accountsReceivable AccountReceivable[]
  transactions       FinancialTransaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("financial_categories")
  @@schema("financeiro")
}

model CostCenter {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  code        String?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  accountsPayable    AccountPayable[]
  accountsReceivable AccountReceivable[]
  transactions       FinancialTransaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("cost_centers")
  @@schema("financeiro")
}

model BankAccount {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  name           String
  bank           String?
  agency         String?
  accountNumber  String?  @map("account_number")
  accountType    String?  @map("account_type")
  pixKey         String?  @map("pix_key")
  initialBalance Decimal  @default(0) @map("initial_balance") @db.Decimal(14, 2)
  currentBalance Decimal  @default(0) @map("current_balance") @db.Decimal(14, 2)
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  transactions   FinancialTransaction[]
  bankStatements BankStatement[]
  paymentsOut    AccountPayable[]
  paymentsIn     AccountReceivable[]

  @@index([tenantId])
  @@map("bank_accounts")
  @@schema("financeiro")
}

model AccountPayable {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String         @map("tenant_id") @db.Uuid
  description        String
  supplierName       String?        @map("supplier_name")
  supplierDocument   String?        @map("supplier_document")
  categoryId         String?        @map("category_id") @db.Uuid
  costCenterId       String?        @map("cost_center_id") @db.Uuid
  bankAccountId      String?        @map("bank_account_id") @db.Uuid
  amount             Decimal        @db.Decimal(14, 2)
  paidAmount         Decimal        @default(0) @map("paid_amount") @db.Decimal(14, 2)
  dueDate            DateTime       @map("due_date") @db.Date
  paymentDate        DateTime?      @map("payment_date") @db.Date
  status             PaymentStatus  @default(PENDING)
  paymentMethod      PaymentMethod? @map("payment_method")
  documentNumber     String?        @map("document_number")
  barcode            String?
  installmentNumber  Int?           @map("installment_number")
  installmentTotal   Int?           @map("installment_total")
  installmentGroupId String?        @map("installment_group_id") @db.Uuid
  recurrenceId       String?        @map("recurrence_id") @db.Uuid
  notes              String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    FinancialCategory? @relation(fields: [categoryId], references: [id])
  costCenter  CostCenter?        @relation(fields: [costCenterId], references: [id])
  bankAccount BankAccount?       @relation(fields: [bankAccountId], references: [id])

  transactions FinancialTransaction[]

  @@index([tenantId])
  @@index([dueDate])
  @@index([status])
  @@map("accounts_payable")
  @@schema("financeiro")
}

model AccountReceivable {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String         @map("tenant_id") @db.Uuid
  description        String
  customerName       String?        @map("customer_name")
  customerDocument   String?        @map("customer_document")
  categoryId         String?        @map("category_id") @db.Uuid
  costCenterId       String?        @map("cost_center_id") @db.Uuid
  bankAccountId      String?        @map("bank_account_id") @db.Uuid
  amount             Decimal        @db.Decimal(14, 2)
  receivedAmount     Decimal        @default(0) @map("received_amount") @db.Decimal(14, 2)
  dueDate            DateTime       @map("due_date") @db.Date
  receivedDate       DateTime?      @map("received_date") @db.Date
  status             PaymentStatus  @default(PENDING)
  paymentMethod      PaymentMethod? @map("payment_method")
  documentNumber     String?        @map("document_number")
  installmentNumber  Int?           @map("installment_number")
  installmentTotal   Int?           @map("installment_total")
  installmentGroupId String?        @map("installment_group_id") @db.Uuid
  recurrenceId       String?        @map("recurrence_id") @db.Uuid
  notes              String?
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    FinancialCategory? @relation(fields: [categoryId], references: [id])
  costCenter  CostCenter?        @relation(fields: [costCenterId], references: [id])
  bankAccount BankAccount?       @relation(fields: [bankAccountId], references: [id])

  transactions FinancialTransaction[]

  @@index([tenantId])
  @@index([dueDate])
  @@index([status])
  @@map("accounts_receivable")
  @@schema("financeiro")
}

model FinancialTransaction {
  id                      String         @id @default(uuid()) @db.Uuid
  tenantId                String         @map("tenant_id") @db.Uuid
  type                    TransactionType
  description             String
  amount                  Decimal        @db.Decimal(14, 2)
  date                    DateTime       @db.Date
  bankAccountId           String?        @map("bank_account_id") @db.Uuid
  categoryId              String?        @map("category_id") @db.Uuid
  costCenterId            String?        @map("cost_center_id") @db.Uuid
  accountPayableId        String?        @map("account_payable_id") @db.Uuid
  accountReceivableId     String?        @map("account_receivable_id") @db.Uuid
  paymentMethod           PaymentMethod? @map("payment_method")
  reconciled              Boolean        @default(false)
  bankStatementId         String?        @map("bank_statement_id") @db.Uuid
  transferToBankAccountId String?        @map("transfer_to_bank_account_id") @db.Uuid
  notes                   String?
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount       BankAccount?       @relation(fields: [bankAccountId], references: [id])
  category          FinancialCategory? @relation(fields: [categoryId], references: [id])
  costCenter        CostCenter?        @relation(fields: [costCenterId], references: [id])
  accountPayable    AccountPayable?    @relation(fields: [accountPayableId], references: [id])
  accountReceivable AccountReceivable? @relation(fields: [accountReceivableId], references: [id])
  bankStatement     BankStatement?     @relation(fields: [bankStatementId], references: [id])

  @@index([tenantId])
  @@index([date])
  @@index([bankAccountId])
  @@index([reconciled])
  @@map("financial_transactions")
  @@schema("financeiro")
}

model BankStatement {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @map("tenant_id") @db.Uuid
  bankAccountId String          @map("bank_account_id") @db.Uuid
  date          DateTime        @db.Date
  description   String
  amount        Decimal         @db.Decimal(14, 2)
  type          TransactionType
  balance       Decimal?        @db.Decimal(14, 2)
  reconciled    Boolean         @default(false)
  importBatch   String?         @map("import_batch")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  transactions FinancialTransaction[]

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([date])
  @@index([reconciled])
  @@map("bank_statements")
  @@schema("financeiro")
}

// ============================================================
// FINANCEIRO SCHEMA: Enums
// ============================================================

enum FinancialCategoryType {
  INCOME
  EXPENSE

  @@schema("financeiro")
}

enum DreGroup {
  GROSS_REVENUE
  DEDUCTIONS
  COST_OF_GOODS
  OPERATING_EXPENSES
  ADMINISTRATIVE_EXPENSES
  PERSONNEL_EXPENSES
  FINANCIAL_INCOME
  FINANCIAL_EXPENSES
  OTHER_INCOME
  OTHER_EXPENSES
  TAXES

  @@schema("financeiro")
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  OVERDUE
  CANCELLED

  @@schema("financeiro")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER

  @@schema("financeiro")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  PIX
  CREDIT_CARD
  DEBIT_CARD
  BOLETO
  CHECK
  OTHER

  @@schema("financeiro")
}

enum ReconciliationStatus {
  OPEN
  IN_PROGRESS
  COMPLETED

  @@schema("financeiro")
}
